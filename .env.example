# Database
DATABASE_URL="file:./dev.db"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
JWT_SECRET="change-this-to-a-random-secret-in-production"
ENCRYPTION_SECRET="change-this-32-char-secret-key!!!!"

# AI Text Generation (optional - uses mock if not set)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Text-to-Speech (optional - video works without audio)
# TTS_PROVIDER sets preference; if it fails, the other configured key is used automatically
TTS_PROVIDER=""
OPENAI_TTS_MODEL="tts-1-hd"
OPENAI_TTS_VOICE="onyx"
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# TikTok Content Posting API (official OAuth)
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:3000/api/tiktok/auth/callback"
